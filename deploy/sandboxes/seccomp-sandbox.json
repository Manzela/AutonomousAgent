{
  "defaultAction": "SCMP_ACT_ERRNO",
  "comment": "Seccomp profile for shell-sandbox container. Deny-by-default with narrow allowlist for safe subprocess execution. CIS Docker Benchmark 5.21.",
  "architectures": [
    "SCMP_ARCH_X86_64",
    "SCMP_ARCH_AARCH64"
  ],
  "syscalls": [
    {
      "names": [
        "read", "write", "close", "fstat", "lstat", "stat",
        "poll", "lseek", "mmap", "mprotect", "munmap",
        "brk", "rt_sigaction", "rt_sigprocmask", "rt_sigreturn",
        "ioctl", "pread64", "pwrite64", "readv", "writev",
        "access", "pipe", "select", "sched_yield",
        "mremap", "msync", "mincore", "madvise",
        "dup", "dup2", "dup3", "nanosleep", "clock_nanosleep",
        "getpid", "sendfile",
        "clone", "fork", "vfork", "execve",
        "exit", "wait4", "kill", "uname",
        "fcntl", "flock", "fsync", "fdatasync",
        "truncate", "ftruncate",
        "getdents", "getdents64",
        "getcwd", "chdir", "fchdir",
        "rename", "mkdir", "rmdir", "creat", "link", "unlink",
        "symlink", "readlink", "chmod", "fchmod",
        "chown", "fchown", "lchown",
        "umask", "gettimeofday", "getrlimit", "setrlimit",
        "getrusage", "sysinfo", "times",
        "getuid", "getgid", "geteuid", "getegid",
        "getgroups", "setgroups",
        "setpgid", "getpgid", "getpgrp", "setsid", "getsid",
        "sigaltstack", "statfs", "fstatfs",
        "prctl", "arch_prctl",
        "futex", "set_tid_address",
        "epoll_create", "epoll_create1", "epoll_ctl", "epoll_wait", "epoll_pwait",
        "clock_gettime", "clock_getres",
        "exit_group", "tgkill",
        "openat", "mkdirat", "fchownat", "newfstatat",
        "unlinkat", "renameat", "linkat", "symlinkat", "readlinkat",
        "fchmodat", "faccessat",
        "set_robust_list", "get_robust_list",
        "pipe2", "eventfd2", "timerfd_create", "timerfd_settime",
        "signalfd4", "accept4", "prlimit64",
        "getrandom", "memfd_create",
        "copy_file_range", "statx",
        "rseq", "close_range", "openat2",
        "newfstatat", "fadvise64",
        "sched_getaffinity",
        "getppid", "getpriority"
      ],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "comment": "Allow socket creation for localhost-only communication (stdin/stdout pipes)",
      "names": [
        "socket", "connect", "accept", "sendto", "recvfrom",
        "sendmsg", "recvmsg", "bind", "listen", "getsockname",
        "getpeername", "socketpair", "setsockopt", "getsockopt",
        "shutdown"
      ],
      "action": "SCMP_ACT_ALLOW"
    }
  ]
}
